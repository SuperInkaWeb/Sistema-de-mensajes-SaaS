# ─── Copia este archivo como .env y completa los valores ───────────────────

# Base de datos PostgreSQL (Render te da esta URL automáticamente)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME"

# JWT Secret - usa una cadena larga y aleatoria en producción
JWT_SECRET="tu-secreto-jwt-super-largo-aqui"

# URL del frontend (Vercel) - importante para CORS
FRONTEND_URL="http://localhost:5173"

# Puerto del servidor (Render lo define automáticamente en producción)
PORT=3001

# Entorno
NODE_ENV="development"
